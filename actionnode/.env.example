# ActionNode — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Server-only, never expose

# ─── Electricity Maps ──────────────────────────────────────────
# Free trial: https://api.electricitymaps.com
# Usage: 100 requests/hour on free tier — cached in Supabase
ELECTRICITY_MAPS_API_KEY=your-electricity-maps-key-here

# ─── Google Gemini ─────────────────────────────────────────────
# Free tier: https://aistudio.google.com/apikey
# Used for: AI-powered Green Swap suggestions
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Open Food Facts ───────────────────────────────────────────
# No key needed — it's fully free and open-source
# https://world.openfoodfacts.org/data

# ─── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production: NEXT_PUBLIC_APP_URL=https://actionnode.vercel.app

# ─── Grid Zones (comma-separated) ──────────────────────────────
GRID_ZONES=AUS-NSW,AUS-VIC,AUS-QLD
GRID_CACHE_MINUTES=10
